{
  "name": "@annguyenvanchuc/todo",
  "version": "1.2.0",
  "homepage": "https://github.com/annguyenwasd/todo",
  "keywords": [
    "todo",
    "cli",
    "task-manager",
    "kanban",
    "ink",
    "react",
    "typescript"
  ],
  "type": "module",
  "bin": {
    "todo": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsc && node dist/cli.js",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "postpublish": "VERSION=$(node -p \"require('./package.json').version\") && gh release create \"v$VERSION\" --title \"v$VERSION\" --generate-notes 2>/dev/null || true",
    "publish:public": "npm publish --access public",
    "install:local": "npm run build && npm install -g .",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "ink": "^7.0.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.0.0"
  }
}
